# 環境固有の設定テンプレート
# このファイルをコピーして .env を作成し、自分の環境に合わせて書き換えてください
#
#   cp .env.example .env
#   # その後、SOJITZ_HOST_PATH を自分の環境に合わせて編集
#

# === ホスト側のデータパス（必須） ===
# Sojitz_poc2.0 ディレクトリの絶対パス
# 例:
#   /data/2024/Sojitz_poc2.0          (本研究室のサーバー)
#   /home/<user>/mnt/Sojitz/2024/Sojitz_poc2.0  (個人マシンでNASをマウントした場合)
SOJITZ_HOST_PATH=/path/to/Sojitz/2024/Sojitz_poc2.0

# === コンテナ設定 ===
COMPOSE_PROJECT_NAME=plos_one_2025
CONTAINER_NAME=PLOS_ONE_2025
IMAGE_TAG=plosone2025:12.9.1-devel-ubuntu24.04_gpu

# === Jupyter ===
JUPYTER_PORT=8888

# === 実行時設定 ===
PYTHONHASHSEED=42
TOKENIZERS_PARALLELISM=false
CUBLAS_WORKSPACE_CONFIG=:16:8
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# === GPU設定 ===
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
